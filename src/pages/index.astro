---
import { Icon } from "astro-icon/components"
import { Picture } from "astro:assets"

import Card from "@/components/cards/Card.astro"
import FeaturedBlogs from "@/components/sections/FeaturedBlogs.astro"
import FeaturedProjects from "@/components/sections/FeaturedProjects.astro"
import FeaturedTestimonials from "@/components/sections/FeaturedTestimonials.astro"
import Hero from "@/components/sections/Hero.astro"
import Work from "@/components/sections/Work.astro"
import Layout from "@/layouts/Layout.astro"

import SkillsBoard from "@/components/sections/SkillsBoard.astro"

import { RESUME_PATH } from "@/utils/data"

import me from "@/img/me.png"
---

<Layout>
  <section id="hero" class="relative overflow-hidden md:p-8">
    <Hero />

    <Card class="mx-auto my-16 w-11/12 md:my-8 md:w-10/12 lg:w-7/12">
      <Picture
        src={me}
        class="aspect-square w-40 -rotate-6 rounded-[3.8rem] rounded-br-3xl border-2 border-neutral-200/50 transition hover:-rotate-18 md:w-52 dark:border-neutral-700/50"
        alt="website owner"
        formats={["avif", "webp"]}
        width={160}
        priority
        slot="image"
      />
      <!-- style="mask-image: radial-gradient(circle at 85% 15%, transparent 5%, black 5%)" -->
      <h2 class="text-3xl font-bold md:text-4xl" slot="title">Hello There</h2>
      <div class="prose prose-lg dark:prose-invert mt-2 leading-7" slot="text">
        I like building systems from first principles, and also play with AI engineering and hack
        around them. I like to work in the Full-Stack, Native and Cloud ecosystems.
      </div>
    </Card>
  </section>

  <!-- Skills section -->
  <section id="skills" class="w-full px-2 py-8 md:p-16">
    <SkillsBoard />
  </section>

  <section id="featured-posts" class="px-2 py-8 md:p-16">
    <div class="mb-2 ps-2 md:mb-8 md:ps-16">
      <h2 class="text-4xl font-bold sm:text-5xl">
        Featured
        <span
          class="bg-teal-500 bg-linear-to-r from-teal-500 via-cyan-400 via-50% to-sky-500 bg-clip-text text-transparent dark:via-cyan-300"
        >
          Blogs
        </span>
      </h2>
      <p class="prose dark:prose-invert mt-2">Some of my top writings.</p>
    </div>
    <FeaturedBlogs />
  </section>

  <section id="featured-projects" class="w-full px-2 py-8 md:p-16">
    <div class="mb-2 ps-2 md:mb-8 md:ps-16">
      <h2 class="text-4xl font-bold sm:text-5xl">
        Exciting
        <span
          class="bg-sky-500 bg-linear-to-r from-sky-500 via-cyan-400 via-50% to-green-500 bg-clip-text text-transparent dark:via-cyan-300"
        >
          Projects
        </span>
      </h2>
      <p class="prose dark:prose-invert mt-2">Small selection of the projects I have worked on.</p>
    </div>
    <FeaturedProjects />
  </section>

  <section id="testimonials" class="px-2 py-8 md:p-16">
    <div class="mx-auto mb-4 md:mb-8">
      <h2 class="font-hand text-center text-3xl font-medium">
        Hear
        <span class="underline"> about me </span>
      </h2>
    </div>
    <FeaturedTestimonials />
  </section>

  <section id="work" class="px-2 py-8 md:p-16">
    <div class="mb-2 ps-2 md:mb-8 md:ps-16">
      <h2 class="text-4xl font-bold sm:text-5xl">Experiences</h2>
      <p class="prose dark:prose-invert mt-2 max-w-none text-[1rem] font-medium">
        Some highlights of my professional experience and the meaningful work I've done so far.
      </p>
    </div>
    <Work />
  </section>

  <div
    class="my-10 flex min-h-[50svh] w-full flex-col place-items-center content-center justify-center space-y-8 p-4 text-center md:my-20 md:space-y-16 md:px-15 md:py-10"
  >
    <h1 class="font-hero text-4xl font-bold md:text-6xl lg:text-8xl">Ready to Work With Me?</h1>
    <p class="font-heading px-4 text-lg font-medium md:px-0 md:text-2xl">
      Grab my Resume and contact me. Let's create something Amazing together!
    </p>

    <div class="flex flex-col items-center justify-center gap-4">
      <a
        href={RESUME_PATH}
        target="_blank"
        data-tippy-content="Get My Resume"
        class="text-sm md:text-base"
      >
        <button
          class="border-opacity-40 group cursor-newtab w-fit rounded-xl border-2 border-neutral-500/50 bg-transparent px-4 py-2 shadow-md transition-shadow hover:shadow-lg md:px-6"
        >
          <Icon
            name="download"
            class="inline translate-y-0 transition-transform duration-200 group-hover:translate-y-1"
            size={24}
          />
          <span class="mx-2 font-mono text-xl opacity-25 md:text-2xl">|</span>
          <span class="font-mono">GET MY <b>RESUME</b></span>
        </button>
      </a>

      <!-- <button
        class="border-opacity-40 group cursor-newtab w-fit rounded-xl border-2 border-neutral-500/50 bg-transparent px-4 py-2 shadow-md transition-shadow hover:shadow-lg md:px-6"
        onclick="navigator.clipboard.writeText('me@harshnj.is-a.dev')"
      >
        <Icon
          name="copy"
          class="inline translate-y-0 transition-transform duration-200 group-hover:translate-y-1"
          size={24}
        />
        <span class="mx-2 font-mono text-xl opacity-25 md:text-2xl">|</span>
        <span class="font-mono">COPY MY <b>EMAIL</b></span>
      </button> -->
    </div>
  </div>
</Layout>
