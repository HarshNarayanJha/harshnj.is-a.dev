---
import { Icon } from "astro-icon/components"
import { Picture } from "astro:assets"

import Card from "@/components/cards/Card.astro"
import FeaturedBlogs from "@/components/sections/FeaturedBlogs.astro"
import FeaturedProjects from "@/components/sections/FeaturedProjects.astro"
import FeaturedTestimonials from "@/components/sections/FeaturedTestimonials.astro"
import Hero from "@/components/sections/Hero.astro"
import SkillsBoard from "@/components/sections/SkillsBoard.astro"
import Work from "@/components/sections/Work.astro"
import Layout from "@/layouts/Layout.astro"

import { RESUME_PATH } from "@/utils/data"

import me from "@/img/me.png"
---

<Layout>
  <!-- hero -->
  <section id="hero" class="relative overflow-hidden md:p-16">
    <Hero />

    <Card class="mx-auto my-16 w-11/12 max-w-7xl md:my-8 md:w-10/12 lg:w-7/12">
      <div
        class="flex h-full flex-col items-center justify-start gap-8 p-8 backdrop-blur-xs md:flex-row md:p-3"
      >
        <div class="self-center">
          <Picture
            src={me}
            class:list={[
              "aspect-square w-40 rounded-[3.8rem] rounded-br-3xl md:w-52",
              "-rotate-6 transition hover:-rotate-18",
              "border-2 shadow-sm",
            ]}
            alt="website-owner"
            formats={["avif", "webp"]}
            width={160}
            priority
          />
        </div>
        <div class="mt-2">
          <h2 class="text-2xl font-bold md:text-3xl">Hello There</h2>
          <div class="prose prose-lg dark:prose-invert mt-2">
            I like building systems from the first principles and exploring the possibilities of AI
            engineering. I love experimenting with new technologies and specialize in building
            creative products with great attention to detail across full-stack, native and cloud
            environments.
          </div>
          <div class="mt-4 mb-2 flex flex-wrap items-center gap-4">
            <a
              href={RESUME_PATH}
              target="_blank"
              class="font-heading bg-surface-2 hover:bg-surface-3 border-border/60 inline-flex items-center gap-1.5 rounded-lg border px-3 py-1.5 text-sm font-semibold transition-colors"
            >
              <Icon name="download" class="size-3.5" />
              Resume
            </a>
            <a
              href="/about"
              class="text-foreground-soft hover:text-foreground text-sm font-semibold underline underline-offset-4 transition-colors"
            >
              More about me &gtdot;
            </a>
          </div>
        </div>
      </div>
    </Card>
  </section>

  <!-- projects -->
  <section id="featured-projects" class="mx-auto w-full max-w-6xl px-4 py-10 md:px-8 md:py-16">
    <div class="mb-6">
      <h2 class="font-heading text-2xl font-bold">Projects</h2>
      <p class="text-foreground-soft mt-1">A selection of things I've built.</p>
    </div>
    <FeaturedProjects />
  </section>

  <!-- experiences -->
  <section id="experience" class="mx-auto w-full max-w-6xl px-4 py-10 md:px-8 md:py-16">
    <div class="mb-6">
      <h2 class="font-heading text-2xl font-bold">Experience</h2>
      <p class="text-foreground-soft mt-1">Where I've worked.</p>
    </div>
    <Work />
  </section>

  <!-- blogs -->
  <section id="featured-posts" class="mx-auto w-full max-w-6xl px-4 py-10 md:px-8 md:py-16">
    <div class="mb-6">
      <h2 class="font-heading text-2xl font-bold">Writing</h2>
      <p class="text-foreground-soft mt-1">Some of my top writings.</p>
    </div>
    <FeaturedBlogs />
  </section>

  <!-- skills -->
  <section id="skills" class="mx-auto w-full max-w-6xl px-4 py-10 md:px-8 md:py-16">
    <div class="mb-6">
      <h2 class="font-heading text-2xl font-bold">Skills</h2>
      <p class="text-foreground-soft mt-1">What I love working with.</p>
    </div>
    <SkillsBoard />
  </section>

  <section id="testimonials" class="mx-auto w-full max-w-6xl px-4 py-10 md:px-8 md:py-16">
    <div class="mx-auto mb-4 md:mb-8">
      <h2 class="font-hand text-center text-3xl font-medium">
        Hear
        <span class="underline"> about me </span>
      </h2>
    </div>
    <FeaturedTestimonials />
  </section>

  <div
    class="relative my-10 flex min-h-[50svh] w-full flex-col place-items-center content-center justify-center space-y-8 p-4 text-center md:my-20 md:space-y-16 md:px-15 md:py-10"
  >
    <div
      id="hero-blob"
      class="bg-primary pointer-events-none absolute m-auto aspect-square w-4/6 rounded-full opacity-10 blur-xl select-none md:w-2/6 md:blur-[96px] dark:opacity-15"
    >
    </div>

    <h1 class="font-hero text-foreground/80 text-4xl font-bold md:text-6xl lg:text-8xl">
      Ready to Work With Me?
    </h1>
    <p class="font-heading px-4 text-lg font-medium md:px-0 md:text-2xl">
      Grab my Resume and contact me. Let's create something Amazing together!
    </p>

    <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href={RESUME_PATH}
        target="_blank"
        data-tippy-content="Get My Resume"
        class="text-sm md:text-base"
      >
        <button
          class="border-opacity-40 group cursor-newtab w-fit rounded-xl border-2 bg-transparent px-4 py-2 text-sm shadow-md transition-shadow hover:shadow-lg md:px-6 md:text-base"
        >
          <Icon
            name="download"
            class="inline translate-y-0 transition-transform duration-200 group-hover:translate-y-1"
            size={24}
          />
          <span class="mx-2 font-mono text-xl opacity-25 md:text-2xl">|</span>
          <span class="font-mono">GET MY <b>RESUME</b></span>
        </button>
      </a>

      <button
        id="copy-email-btn"
        class="border-opacity-40 group w-fit cursor-pointer rounded-xl border-2 bg-transparent px-4 py-2 text-sm shadow-md transition-all hover:shadow-lg md:px-6 md:text-base"
        data-tippy-content="Copy Email Address"
      >
        <Icon
          name="copy"
          class="inline translate-y-0 transition-transform duration-200 group-hover:translate-y-1"
          size={24}
        />
        <span class="mx-2 font-mono text-xl opacity-25 md:text-2xl">|</span>
        <span id="copy-email-text" class="font-mono">COPY MY <b>EMAIL</b></span>
      </button>
    </div>
  </div>
</Layout>

<script>
  function setupCopyEmail() {
    const btn = document.getElementById("copy-email-btn")
    const text = document.getElementById("copy-email-text")
    if (!btn || !text) return

    let timeout: number | null = null
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText("me@harshnj.is-a.dev")
        text.innerHTML = "EMAIL <b>COPIED!</b>"
        btn.classList.add("border-secondary/50", "text-secondary")
        if (timeout) clearTimeout(timeout)
        timeout = setTimeout(() => {
          text.innerHTML = "COPY MY <b>EMAIL</b>"
          btn.classList.remove("border-secondary/50", "text-secondary")
        }, 2000) as unknown as number
      } catch (err) {
        console.error("Failed to copy: ", err)
      }
    })
  }

  document.addEventListener("astro:page-load", setupCopyEmail)
</script>
