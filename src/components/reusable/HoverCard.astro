---
interface Props {
  id?: string
}

const { id = "hover-card" } = Astro.props
---

<div
  id={id}
  class="border-border/50 bg-surface-3 pointer-events-none fixed z-50 flex w-72 scale-95 flex-col gap-3 rounded-xl border p-4 opacity-0 shadow-2xl backdrop-blur-md transition-all duration-300 md:w-80"
>
  <img
    data-hover-img
    src=""
    alt="Preview"
    class="border-border/50 aspect-video w-full rounded-lg border object-cover"
  />
  <div class="space-y-1">
    <div class="flex items-center justify-between">
      <kbd data-hover-tags class="prose dark:prose-invert font-mono text-xs"></kbd>
      <span data-hover-time class="text-muted font-mono text-xs"></span>
    </div>
    <h4 data-hover-title class="font-heading line-clamp-1 text-sm font-semibold"></h4>
    <p data-hover-desc class="text-foreground-soft line-clamp-3 text-sm leading-relaxed"></p>
  </div>
</div>
