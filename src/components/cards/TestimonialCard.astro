---
import { Image } from "astro:assets"
import type { CollectionEntry } from "astro:content"

import TransparentBorder from "@/components/reusable/TransparentBorder.astro"

interface Props {
  class: string
  testimonial: CollectionEntry<"testimonials">["data"]
  [key: string]: any
}

const { class: className, testimonial, ...rest } = Astro.props
---

<TransparentBorder class:list={[className, "border-0"]} {rest}>
  <div
    class:list={[
      "bg-card text-card-foreground flex h-full flex-col items-start justify-between gap-4 rounded-lg px-8 py-8 md:px-6",
      // "shadow-neutral-600/50 drop-shadow-sm",
    ]}
  >
    <slot name="title" />
    <div class="w-full">
      <slot name="text" />
    </div>

    <div class="mt-2 flex flex-row items-center justify-start gap-2">
      <Image
        src={testimonial.img}
        alt={testimonial.name}
        width={96}
        class="inline-block h-10 w-10 rounded-full"
      />
      <div>
        <slot name="name" />
        <slot name="at" />
      </div>
    </div>
  </div>
</TransparentBorder>
