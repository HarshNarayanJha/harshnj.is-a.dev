---
import { Image } from "astro:assets"
import type { CollectionEntry } from "astro:content"

interface Props {
  class: string
  testimonial: CollectionEntry<"testimonials">["data"]
  [key: string]: any
}

const { class: className, testimonial, ...rest } = Astro.props
---

<div
  class:list={[
    "bg-surface overflow-hidden rounded-xl p-6 md:p-8",
    "relative flex h-full flex-col items-start justify-between gap-6 md:flex-row md:items-center",
    "shadow-xs transition-all duration-300 hover:shadow-md",
    className,
  ]}
  {...rest}
>
  <div
    class="bg-primary/25 pointer-events-none absolute -right-24 -bottom-24 h-48 w-48 rounded-full blur-lg md:blur-3xl"
  >
  </div>

  <div class="space-y-2">
      <slot name="title" />
      <slot name="text" />
  </div>

  <div
    class="flex shrink-0 flex-row items-center justify-start gap-3 select-none md:w-48 md:flex-col md:justify-center md:pl-8 md:text-center"
  >
    <Image
      src={testimonial.img}
      alt={testimonial.name}
      width={96}
      class="h-10 w-10 shrink-0 rounded-full object-cover md:h-24 md:w-24"
    />
    <div class="flex flex-col gap-0.5 md:w-full md:gap-1">
      <slot name="name" />
      <slot name="at" />
    </div>
  </div>
</div>
