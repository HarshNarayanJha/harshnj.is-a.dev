---
import TransparentBorder from "@/components/reusable/TransparentBorder.astro"
import { Picture } from "astro:assets"
import type { CollectionEntry } from "astro:content"

interface Props {
  class: string
  work: CollectionEntry<"experiences">["data"]
  [key: string]: any
}

const { class: className, work, ...rest } = Astro.props
---

<TransparentBorder class:list={[className, "border-0"]} {rest}>
  <div
    class:list={[
      "bg-card text-card-foreground flex h-full flex-col items-start justify-start gap-4 p-4 md:flex-row md:gap-6 md:p-4",
      // "shadow-neutral-600/50 drop-shadow-sm",
    ]}
  >
    <div class="self-center">
      <Picture
        src={work.logo!}
        formats={["webp", "avif"]}
        alt={work.at}
        class:list={[
          "rounded-2xl border-2 border-b-0 border-neutral-200/50 dark:border-neutral-600/50",
        ]}
        layout="constrained"
      />
    </div>
    <div class="mt-2 w-full sm:mt-4">
      <slot name="title" />
      <slot name="text" />
    </div>
  </div>
</TransparentBorder>
