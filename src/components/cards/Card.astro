---
import TransparentBorder from "@/components/reusable/TransparentBorder.astro"

interface Props {
  class: string
  [key: string]: any
}

const { class: className, ...rest } = Astro.props
---

<TransparentBorder class:list={[className, "border-0"]} {rest}>
  <div
    class:list={[
      "bg-card/80 text-card-foreground flex h-full flex-col items-center justify-start gap-8 rounded-lg p-12 backdrop-blur-xs will-change-transform md:flex-row md:p-4",
    ]}
  >
    <div class="self-center">
      <slot name="image" />
    </div>
    <div class="mt-2">
      <slot name="title" />
      <slot name="text" />
    </div>
  </div>
</TransparentBorder>
