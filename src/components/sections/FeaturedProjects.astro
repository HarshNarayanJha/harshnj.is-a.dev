---
import { getCollection } from "astro:content"
import FeaturedProjectsList from "./FeaturedProjectsList.svelte"

const featuredProjects = await getCollection("projects", ({ data }) => data.featured)

// Sort by year in reverse
const sortedProjects = featuredProjects.sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0))

const projectsData = sortedProjects.map(proj => ({
  id: proj.id,
  name: proj.data.name,
  text: proj.data.text,
  url: proj.data.url,
  github: proj.data.github,
  domains: proj.data.domains,
  tags: proj.data.tags,
  year: proj.data.year,
  status: proj.data.status,
  img: proj.data.img ? proj.data.img.src : "",
}))
---

<FeaturedProjectsList client:load projects={projectsData} />

<div class="mt-6 text-center">
  <a
    href="/projects"
    class="prose dark:prose-invert text-sm font-semibold underline underline-offset-4 transition-colors duration-300 hover:text-teal-500 dark:hover:text-teal-400"
  >
    Analyze more projects &gtdot;
  </a>
</div>
