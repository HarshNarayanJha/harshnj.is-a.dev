---
import { getCollection } from "astro:content"
import { formatDate } from "@/utils"
import { getReadingTime } from "@/utils/reading-time"
import CompactRow from "@/components/cards/CompactRow.astro"
import placeholderImage from "@/img/placeholder.png"

const featuredBlogs = (
  await getCollection("blogs", ({ data }) => data.isPublished && data.pubDate && data.isVisible)
)
  .sort((a, b) => b.data.pubDate!.valueOf() - a.data.pubDate!.valueOf())
  .slice(0, 3)
---

<div class="divide-border/30 divide-y">
  {
    featuredBlogs.map(blog => {
      const readingTime = getReadingTime(blog.body ?? "")
      const tagsStr = blog.data.tags.map(t => `#${t}`).join("  ")
      const dateStr = blog.data.pubDate ? formatDate(blog.data.pubDate) : "Draft"

      return (
        <CompactRow
          href={`/blog/${blog.id}`}
          title={blog.data.title}
          description={blog.data.description}
          logo={blog.data.image ?? placeholderImage}
          logoAlt={blog.data.title}
          logoWidth={96}
          logoHeight={64}
          logoClass="border-border/40 hidden h-16 w-24 shrink-0 overflow-hidden rounded-lg border sm:block object-cover"
        >
          <span slot="header" class="text-muted font-mono text-xs font-semibold">
            {dateStr}
          </span>
          <div
            slot="footer"
            class="text-muted mt-2 flex items-center justify-between font-mono text-xs"
          >
            <span>{readingTime}</span>
            <span>{tagsStr}</span>
          </div>
        </CompactRow>
      )
    })
  }
</div>

<div class="mt-6 text-center">
  <a
    href="/blog"
    class="text-muted hover:text-primary text-sm font-semibold underline underline-offset-4 transition-colors duration-300"
  >
    Read more blogs &gtdot;
  </a>
</div>
