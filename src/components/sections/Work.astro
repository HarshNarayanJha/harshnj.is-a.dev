---
import { formatMonth } from "@/utils"
import { Icon } from "astro-icon/components"
import { getCollection } from "astro:content"
import CompactRow from "@/components/cards/CompactRow.astro"

const works = (await getCollection("experiences", ({ data }) => data.type == "work")).sort(
  (a, b) => b.data.start.valueOf() - a.data.start.valueOf(),
)
---

<div class="divide-y divide-border/30">
  {
    works.map(work => {
      const durationStr = `${formatMonth(work.data.start)} — ${
        work.data.end === "PRESENT" ? "Present" : formatMonth(work.data.end)
      }`

      return (
        <div class="flex flex-col md:flex-row gap-4 py-5 items-start">
          <div class="w-full md:w-36 shrink-0 pt-4 font-mono text-xs font-semibold text-muted">
            {durationStr}
          </div>

          <div class="flex-1 min-w-0 w-full">
            <CompactRow
              class="px-6 py-4 hover:bg-transparent"
              title={`${work.data.role} · ${work.data.at}`}
              description={work.data.description}
              logo={work.data.logo}
              logoAlt={work.data.at}
              logoClass="mt-0.5"
            >
              <div slot="footer" class="flex flex-wrap items-center gap-x-3 gap-y-0.5 mt-2 text-muted font-mono text-xs">
                {work.data.link && (
                  <a
                    href={work.data.link}
                    target="_blank"
                    class="text-secondary hover:underline inline-flex items-center gap-0.5"
                  >
                    {work.data.link.replace(/^https?:\/\/(www\.)?/, "")}
                    <Icon name="link" class="inline size-3" />
                  </a>
                )}
                {work.data.link && <span class="text-border">•</span>}
                <span>{work.data.location}</span>
              </div>
            </CompactRow>
          </div>
        </div>
      )
    })
  }
</div>

<div class="mt-6 text-center">
  <a
    href="/about#about-experiences"
    class="text-muted hover:text-primary text-sm font-semibold underline underline-offset-4 transition-colors duration-300"
  >
    Full experience history &gtdot;
  </a>
</div>
