---
import Glyphs from "../reusable/Ghlyps.astro"

// const roles = ["Developer", "Problem Solver", "Open-Source contributor"]
const roles = ["Systems", "AI Engineering", "Full-Stack"]
---

<main
  class="mt-32 flex min-h-[50svh] w-full flex-col items-center justify-start p-8 text-center md:mt-[10svh]"
>
  <div
    id="hero-blob"
    class="bg-secondary pointer-events-none absolute m-auto aspect-square w-4/6 rounded-full opacity-30 blur-xl select-none md:w-2/6 md:blur-[96px] dark:opacity-25 md:dark:opacity-15"
  >
  </div>

  <!-- Grid BG -->
  <div
    class="pointer-events-none absolute inset-0 z-0 h-full w-full opacity-50 dark:opacity-35"
    style="background-image: radial-gradient(var(--color-primary) 1px, transparent 1px); background-size: 24px 24px;"
  >
  </div>

  <h1
    id="hero-name"
    class="font-hero z-10 mt-10 transform-gpu bg-linear-to-r from-zinc-200 via-neutral-600 via-40% bg-clip-text py-4 text-6xl font-black tracking-wide text-transparent sm:text-7xl md:text-8xl md:backdrop-blur-xs dark:from-stone-700 dark:via-zinc-200 dark:via-30% dark:to-zinc-50"
    style="mask: linear-gradient(transparent, black 15%, black 85%, transparent)"
  >
    This is
    <span
      class="from-secondary via-primary bg-linear-to-br from-20% via-70% to-transparent bg-clip-text text-transparent md:drop-shadow-[0_0_8px_lightblue] dark:drop-shadow-[0_0_8px_black]"
    >
      Harsh Narayan Jha
    </span>
  </h1>

  <!-- <Glyphs /> -->

  <div
    class="font-array text-foreground-soft/80 z-10 mt-8 items-center gap-4 text-lg tracking-wider"
  >
    {
      roles.map((role, index) => {
        return (
          <>
            <span>{role.toUpperCase()}</span>
            {index < roles.length - 1 && <span class="font-array text-secondary">x</span>}
          </>
        )
      })
    }
  </div>
  <!-- getting rid of "hero" tags for now -->
  <!-- <h2
    id="hero-tags"
    class="font-array z-10 mt-4 animate-pulse py-4 text-xl font-semibold text-neutral-700 opacity-90 md:mt-8 md:text-2xl md:backdrop-blur dark:text-neutral-300"
    style="mask: linear-gradient(transparent, black 25%, black 75%, transparent)"
  >
    {
      roles.map(role => (
        <span>
          {role} <br />
        </span>
      ))
    }
  </h2> -->
</main>
