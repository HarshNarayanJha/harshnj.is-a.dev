---
import { skills } from "@/utils/data"
import { Icon } from "astro-icon/components"

const systems = skills.filter(s => s.skillType === "systems")
const frameworks = skills.filter(s => s.skillType === "frameworks")
const languages = skills.filter(s => s.skillType === "languages")
const intelligence = skills.filter(s => s.skillType === "intelligence")

let currentOffset = 0
const categories = [
  {
    title: "Systems",
    items: systems,
  },
  {
    title: "Frameworks",
    items: frameworks,
  },
  {
    title: "Languages",
    items: languages,
  },
  {
    title: "Intelligence",
    items: intelligence,
  },
].map(cat => {
  const hexCode = "0x" + currentOffset.toString(16).padStart(2, "0")
  currentOffset += cat.items.length
  return {
    ...cat,
    code: hexCode,
  }
})

const totalSkillsHex = "0x" + currentOffset.toString(16).padStart(2, "0")
---

<div class="font-mono text-sm py-4">
  <div class="space-y-6">
    {
      categories.map(cat => (
        <div class="relative">
          <div class="text-muted mb-2 flex items-center text-xs font-bold tracking-wider uppercase select-none">
            <span class="text-secondary/80 mr-1.5">[{cat.code}]</span>
            <span>{cat.title}</span>
          </div>

          <div class="ml-4 flex flex-wrap gap-2 border-l border-dashed py-1 pl-4">
            {cat.items.map(skill => (
              <div
                title={skill.tooltip}
                class="group flex items-center gap-2 rounded-lg border-2 border-border/50 px-3 py-1.5 transition-colors hover:border-(--icon-color) hover:bg-surface-2 dark:hover:border-(--icon-dark-color)"
                style={{
                  "--icon-color": skill.color,
                  "--icon-dark-color": skill.darkColor || skill.color,
                }}
              >
                {skill.logo && (
                  <Icon
                    name={skill.logo}
                    class="h-4 w-4 text-(--icon-color) transition-transform duration-200 dark:text-(--icon-dark-color)"
                  />
                )}
                <span class="text-foreground-soft text-xs font-semibold">{skill.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))
    }

    {/* EOF Address Indicator */}
    <div class="text-muted flex items-center text-xs font-bold tracking-wider uppercase select-none">
      <span class="text-secondary/80 mr-1.5">[{totalSkillsHex}]</span>
      <span>EOF</span>
    </div>
  </div>
</div>
