---
import { skills } from "@/utils/data"
import { Icon } from "astro-icon/components"

const systems = skills.filter(s => s.skillType === "systems")
const frameworks = skills.filter(s => s.skillType === "frameworks")
const languages = skills.filter(s => s.skillType === "languages")
const intelligence = skills.filter(s => s.skillType === "intelligence")

const categories = [
  {
    code: "0x01",
    title: "Systems",
    items: systems,
  },
  {
    code: "0x02",
    title: "Frameworks",
    items: frameworks,
  },
  {
    code: "0x03",
    title: "Languages",
    items: languages,
  },
  {
    code: "0x04",
    title: "Intelligence",
    items: intelligence,
  },
]
---

<div
  class="bg-surface relative w-full overflow-hidden rounded-xl border p-4 font-mono text-sm shadow-sm"
>
  <div class="mb-6 flex items-center justify-between border-b pb-4">
    <div class="flex items-center gap-2">
      <span class="h-3 w-3 rounded-full bg-red-500/80"></span>
      <span class="h-3 w-3 rounded-full bg-yellow-500/80"></span>
      <span class="h-3 w-3 rounded-full bg-green-500/80"></span>
      <span class="text-foreground-soft ml-2 font-mono text-xs"> harshnj@arch:~ </span>
    </div>
    <span class="text-muted font-mono text-xs">LANGS & TOOLS</span>
  </div>

  <div class="space-y-6">
    {
      categories.map(cat => (
        <div class="relative">
          <div class="text-muted mb-2 flex items-center text-xs font-bold tracking-wider uppercase select-none">
            <span class="text-secondary/80 mr-1.5">[{cat.code}]</span>
            <span>{cat.title}</span>
          </div>

          <div class="ml-4 flex flex-wrap gap-2 border-l border-dashed py-1 pl-4">
            {cat.items.map(skill => (
              <div
                title={skill.tooltip}
                class="group group-hover:bg-surface-2 border-border/50 flex items-center gap-2 rounded-lg border-2 px-3 py-1.5 transition-colors hover:border-(--icon-color) dark:hover:border-(--icon-dark-color)"
                style={{
                  "--icon-color": skill.color,
                  "--icon-dark-color": skill.darkColor || skill.color,
                }}
              >
                {skill.logo && (
                  <Icon
                    name={skill.logo}
                    class="h-4 w-4 text-(--icon-color) transition-transform duration-200 dark:text-(--icon-dark-color)"
                  />
                )}
                <span class="text-foreground-soft text-xs font-semibold">{skill.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</div>
