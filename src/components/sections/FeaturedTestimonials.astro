---
import TestimonialCard from "@/components/cards/TestimonialCard.astro"
import { getCollection } from "astro:content"

const testimonials = await getCollection("testimonials", t => t.data.isPublished === true)
---

<div class="w-full">
  {
    testimonials.map(t => (
      <TestimonialCard class="mx-auto max-w-4xl" testimonial={t.data}>
        <h4 class="font-heading text-lg font-bold" slot="title">
          {t.data.title}
        </h4>
        <p class="prose dark:prose-invert text-[0.975rem] whitespace-pre-line" slot="text">
          {t.data.text}
        </p>
        <h4 class="font-bold" slot="name">
          {t.data.name}
        </h4>
        <p class="text-foreground-soft text-sm" slot="at">
          {t.data.at} &mdash; <span class="font-sans italic">{t.data.position}</span>
        </p>
      </TestimonialCard>
    ))
  }
</div>
